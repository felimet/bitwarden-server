# =============================================================================
# Vaultwarden 環境變數設定檔
# =============================================================================
# 使用方式：複製本檔案為 .env，然後根據實際環境填寫各項參數
#   cp .env.template .env
#
# 📖 完整變數參考（含所有可用選項與預設值）：
#   vaultwarden/.env.template（官方原始碼內建範本，667 行完整說明）
#   https://github.com/dani-garcia/vaultwarden/wiki
#
# ⚠️ 注意：部分設定若透過 Admin 面板修改，會儲存於 bw-data/config.json 並覆蓋此處的值。
# =============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  核心設定（必填）                                                        ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# 對外存取域名（必須包含 https:// 前綴）
# 此為 Vaultwarden 最關鍵的設定，影響附件下載、Email 連結、U2F/WebAuthn 等功能
DOMAIN=https://vault.example.com

# Cloudflare Tunnel Token（從 Cloudflare Zero Trust 儀表板取得）
# 取得方式請參考 docs/cloudflare-tunnel.md
CLOUDFLARE_TUNNEL_TOKEN=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  安全設定                                                                ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# 公開註冊開關（建立管理者帳號後務必改為 false）
SIGNUPS_ALLOWED=true

# 允許受邀使用者在註冊關閉後仍可透過邀請連結加入
INVITATIONS_ALLOWED=true

# 若需限制僅特定域名可註冊（以逗號分隔），即使 SIGNUPS_ALLOWED=false 亦允許
# SIGNUPS_DOMAINS_WHITELIST=example.com,example.org

# 新使用者註冊時是否需要驗證 Email
SIGNUPS_VERIFY=true

# Admin 面板驗證 Token（未設定則 Admin 面板停用）
# 建議使用 Argon2 PHC 格式（可用 `vaultwarden hash` 產生）
# 次選使用 `openssl rand -base64 128` 產生隨機字串
# ⚠️ 在 docker-compose 環境中，Argon2 字串內的 $ 需用 $$ 跳脫
ADMIN_TOKEN=

# Admin 面板速率限制
# 限制：每 300 秒（5 分鐘）恢復 1 次嘗試額度，最多允許連續輸錯 3 次
# ⚠️ 警告：若使用 Cloudflare Tunnel，未設定下方 IP_HEADER 將導致全站使用者被共用 IP 封鎖！
ADMIN_RATELIMIT_SECONDS=300
ADMIN_RATELIMIT_MAX_BURST=3

# Admin 面板 Session 有效時間（分鐘）
ADMIN_SESSION_LIFETIME=20

# 登入速率限制
# 限制：每 60 秒（1 分鐘）恢復 1 次嘗試額度，最多允許連續輸錯 10 次
# ⚠️ 警告：同上，若啟用此防護，必須搭配真實 IP 標頭識別。
LOGIN_RATELIMIT_SECONDS=60
LOGIN_RATELIMIT_MAX_BURST=10

# 獲取客戶端真實 IP（用於速率限制計數）
# 啟用速率限制前「必須」設置此項，因預設來源 IP 皆會解析為 Cloudflared 內部 IP (如 172.x.x.x)
IP_HEADER=X-Forwarded-For

# 密碼迭代次數（PBKDF2-SHA256，預設 600,000 次，符合 OWASP 建議）
PASSWORD_ITERATIONS=600000


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  推播通知（行動裝置即時同步）                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 啟用後行動裝置可即時收到密碼庫變更通知（無須手動同步）
# 需前往 https://bitwarden.com/host/ 免費申請 Installation ID 與 Key
# 詳細說明：https://github.com/dani-garcia/vaultwarden/wiki/Enabling-Mobile-Client-push-notification

PUSH_ENABLED=true
PUSH_INSTALLATION_ID=
PUSH_INSTALLATION_KEY=

# 推播伺服器位址（預設為美國區域，歐盟區域請切換）
PUSH_RELAY_URI=https://push.bitwarden.com
PUSH_IDENTITY_URI=https://identity.bitwarden.com
## 歐盟區域：
# PUSH_RELAY_URI=https://api.bitwarden.eu
# PUSH_IDENTITY_URI=https://identity.bitwarden.eu


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  資料庫設定                                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 預設使用 SQLite（最輕量，適合 NAS 環境），資料庫檔案位於 /data/db.sqlite3
# 亦支援 MySQL 與 PostgreSQL：
#   MySQL:      mysql://user:password@host[:port]/database_name
#   PostgreSQL: postgresql://user:password@host[:port]/database_name

DATABASE_URL=data/db.sqlite3

# 啟用 SQLite WAL 模式（顯著提升並發讀寫效能，建議保持預設啟用）
ENABLE_DB_WAL=true

# 資料庫連線池設定（SQLite 環境一般不需調整）
DATABASE_MAX_CONNS=10
DATABASE_TIMEOUT=30


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SMTP 郵件通知                                                           ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 未配置將導致：無法使用 Email 2FA、無法收到新裝置登入通知、
# 無法使用 Admin 面板邀請使用者、無法重設密碼
# 若無 SMTP 可用，仍可正常使用密碼管理功能

SMTP_HOST=smtp.gmail.com
# 你希望收件人看到的寄件者信箱（通常為你的 Gmail 地址）
SMTP_FROM=vaultwarden@example.com
# 收件匣中顯示的寄件者名稱
SMTP_FROM_NAME=Vaultwarden
SMTP_PORT=587
SMTP_SECURITY=starttls
# 你的完整 Gmail 地址
SMTP_USERNAME=your_email@gmail.com
# ⚠️ 這裡「不可以」填你的 Google 一般登入密碼，必須填寫 16 碼的應用程式密碼
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP 安全連線方式：
#   starttls  — Port 587（STARTTLS，預設推薦）
#   force_tls — Port 465（隱式 TLS）
#   off       — Port 25（不加密，僅限內部網路）

# 將 Logo 等圖片嵌入郵件而非外部連結
SMTP_EMBED_IMAGES=true


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  WebSocket 即時同步                                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 啟用 WebSocket 後，密碼庫變更可即時推送至已連線的客戶端
# 預設已啟用（Vaultwarden >= 1.29.0 後為內建 WebSocket）

ENABLE_WEBSOCKET=true


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  進階圖示設定                                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 控制密碼項目旁的網站圖示如何取得與快取

# 圖示來源（internal / bitwarden / duckduckgo / google）
ICON_SERVICE=internal

# 停用圖示下載（使用已快取的，不發起對外網路請求）
DISABLE_ICON_DOWNLOAD=false

# 圖示快取 TTL（秒），預設 30 天
ICON_CACHE_TTL=2592000

# 封鎖特定 IP 範圍的圖示請求（防止 SSRF 攻擊）
# ⚠️ 此正規表達式需以單引號包裹
HTTP_REQUEST_BLOCK_REGEX='^(192\.168\.0\.[0-9]+|192\.168\.1\.[0-9]+)$'

# 封鎖所有非全域 IP 的請求（更強力的 SSRF 防護）
HTTP_REQUEST_BLOCK_NON_GLOBAL_IPS=true


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  MFA / 2FA 多因素認證                                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Yubikey OTP 設定（前往 https://upgrade.yubico.com/getapikey/ 取得）
# YUBICO_CLIENT_ID=
# YUBICO_SECRET_KEY=

# Duo 設定（前往 Duo Security 建立應用程式）
# DUO_IKEY=
# DUO_SKEY=
# DUO_HOST=

# Email 2FA (電子郵件兩步驟驗證) 參數設定
EMAIL_TOKEN_SIZE=6        # 驗證碼長度（預設為 6 位數字字串）
EMAIL_EXPIRATION_TIME=600 # 驗證碼的有效時間（預設為 600 秒 / 10 分鐘，過期即失效）
EMAIL_ATTEMPTS_LIMIT=3    # 允許錯誤輸入的最大次數（預設 3 次，超過次數將強制要求重新發送一封新的驗證信）

# 停用「30 天記住此裝置」（強制每次登入皆需 2FA）
DISABLE_2FA_REMEMBER=false

# 2FA 未完成登入通知（分鐘，0=停用）
INCOMPLETE_2FA_TIME_LIMIT=3


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SSO 單一登入（OpenID Connect）                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 支援透過 OIDC 提供者（如 Authelia、Keycloak、Authentik）登入

# SSO_ENABLED=false
# SSO_ONLY=false
# SSO_AUTHORITY=https://auth.example.com
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_SCOPES="email profile"
# SSO_PKCE=true


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  組織與功能控制                                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# 組織事件日誌（稽核紀錄），預設關閉
# 說明：啟用後會詳細記錄該組織內所有人員的操作（如：誰在何時檢視了密碼、新增了密碼、修改了權限等）。
# ⚠️ 注意：這會產生大量的資料庫寫入操作（IOPS），並隨時間逐漸佔用資料庫的儲存空間。若無合規稽核需求建議關閉。
ORG_EVENTS_ENABLED=false

# 組織群組功能（Beta），預設關閉
# 說明：企業級進階功能，允許將使用者分類至不同的「群組（Groups）」，並透過群組統一指派「密碼集合（Collections）」的存取權限。
# 適用於幾十人以上且權限層級複雜（如：研發部、財務部、外包商）的管理情境。單純家庭或個人使用則不需要。
ORG_GROUPS_ENABLED=false

# 限制哪些使用者可以建立組織（all / none / 逗號分隔的 email）
# 說明：為避免伺服器內隨意產生大量幽靈組織，限制建立組織的權限。
# 設為 `none` 代表只有系統管理員能在 Admin 面板建立；或填入你的帳號 `user@example.com` 鎖定專屬權限。
# ORG_CREATION_USERS=

# 緊急存取 (Emergency Access) 功能開關
# 說明：數位遺產 / 備援機制。允許設定「緊急聯絡人」，當發生意外（如喪失行為能力、忘記主密碼）時，
# 緊急聯絡人可向伺服器發起存取請求。若原擁有者在設定的寬限期（如 7 天）內未拒絕，
# 聯絡人將獲得密碼庫的「唯讀 (View)」或「接管 (Takeover)」權限。
# ⚠️ 注意：必須依賴 SMTP 郵件通知功能才能正常運作（寄送警報與請求通知）。
EMERGENCY_ACCESS_ALLOWED=true

# Bitwarden Send (安全傳送) 功能開關
# 說明：允許使用者建立「端到端加密」的限時、閱後即焚連結，將文字或檔案安全地分享給任何人（即使對方沒有 Bitwarden 帳號）。
# ⚠️ 注意：若啟用此功能並允許傳送檔案，請留意伺服器硬碟空間。可搭配排程工作（SEND_PURGE_SCHEDULE）定期清理過期檔案。
SENDS_ALLOWED=true

# 垃圾桶自動清除天數（未設定則不自動清除）
TRASH_AUTO_DELETE_DAYS=90

# HaveIBeenPwned API Key（付費密碼洩漏檢查）
# 說明：設定此 Key 後，能在 Web Vault 或客戶端執行「資料外洩檢查報表」
# 取得方式：需至 https://haveibeenpwned.com/API/Key 購買授權（每月 $3.50 USD 以上）
# ⚠️ 注意：未填寫此項時，客戶端仍可驗證單筆「外洩密碼」，但無法產出完整的詳細外洩報表
# HIBP_API_KEY=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  日誌與除錯                                                                ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# 日誌檔案路徑（容器內路徑，會寫入掛載的 bw-data 目錄）
LOG_FILE=/data/vaultwarden.log

# 日誌等級：trace / debug / info / warn / error / off
LOG_LEVEL=warn

# 擴展日誌格式（含時間戳記與模組名稱）
EXTENDED_LOGGING=true

# 時間戳記格式
LOG_TIMESTAMP_FORMAT="%Y-%m-%d %H:%M:%S.%3f"


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  排程工作                                                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 用於控制與設定 Vaultwarden 自動「定期清理歷史包袱與無用資料」的時間表。
# 當伺服器長時間運作時，若不清理，資料庫或儲存空間可能會被佔滿。
# 說明：Vaultwarden 內建的非同步任務排程器設定。必須保持 `JOB_POLL_INTERVAL_MS`（輪詢間隔）大於 0（預設 30000 即 30 秒）才能讓後續排程生效。
# 使用 cron 語法，採用 UTC 時間（不隨 TZ 變數改變），格式為：秒 分 時 日 月 星期

# 排程輪詢間隔（毫秒），設為 0 會全局強制停用所有排程功能（不建議）
# 伺服器每隔多久要檢查一次看有沒有設定的任務該執行了？
JOB_POLL_INTERVAL_MS=30000

# Send 安全分享的過期清理排程（預設：每小時的第 5 分鐘執行）
# 說明：定期掃描並清除使用者分享出去且「已過期」的文字或檔案實體，釋放硬碟空間。
SEND_PURGE_SCHEDULE="0 5 * * * *"

# 垃圾桶永久刪除排程（預設：每天 UTC 00:05 執行）
# 說明：搭配 TRASH_AUTO_DELETE_DAYS 設定，固定於半夜清除被丟入垃圾桶達指定天數的密碼。
TRASH_PURGE_SCHEDULE="0 5 0 * * *"

# 組織事件日誌清理排程（預設：每天 UTC 00:10 執行）
# 說明：如果你前幾個步驟（如：開啟組織稽核紀錄）這項被你設定為 TRUE，因為那會無止盡的寫入事件，你必須透過這個參數，
# 定期清除老舊的稽核日誌，防止 SQLite 檔案過度膨脹。
# ⚠️ 必須與 `EVENTS_DAYS_RETAIN`（保留天數，如 `30`）同時設定才會生效。
EVENT_CLEANUP_SCHEDULE="0 10 0 * * *"
EVENTS_DAYS_RETAIN=30

# 💡 補充說明： Vaultwarden 的 Cron 只看 UTC 標準時間。
# 即便我們在最後一行設定了 TZ=Asia/Taipei 使得 Log 出來的時間變成台灣時區，排程觸發的起算點依然是 UTC 0 點（即台灣的早上 8 點）。
# 所以如果你設定每天半夜十二點執行，在台灣其實是早上八點才會被啟動打掃！這屬正常現象無需擔心過度。

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  實驗性功能旗標                                                             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
# 說明：強制為連線到這台伺服器的所有 Bitwarden 客戶端（包含手機 APP、電腦版與瀏覽器擴充功能）啟用某些目前官方仍在「測試/實驗階段」的隱藏功能。
# ⚠️ 注意：這只對官方原生客戶端有效。且客戶端對這項設定的拉取快取（Cache）大約長達 1 小時，因此即使你在此啟用，客戶端可能也要等上一小時才會出現新功能介面，重啟容器無法加速客戶端快取失效。
# 
# 採用半形逗號（,）分隔。目前可用的旗標包含（截至 2025 年）：
#   ssh-agent                — Desktop SSH Agent 支援 (讓 Bitwarden 電腦版能作為本機的 SSH 代理伺服器)
#   ssh-key-vault-item       — SSH Key Vault Item (允許密碼庫原生支援儲存與管理 SSH Key 格式)
#   export-attachments       — 匯出附件 (在備份/匯出 Vault 時，允許一併將所有加密夾帶的附檔匯出)
#   inline-menu-totp         — 瀏覽器擴充 inline menu TOTP (在網頁輸入框的右鍵小選單內，直接允許複製 2FA 兩步驟驗證碼)
# ex. EXPERIMENTAL_CLIENT_FEATURE_FLAGS=ssh-key-vault-item, inline-menu-totp
EXPERIMENTAL_CLIENT_FEATURE_FLAGS=inline-menu-totp


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  時區設定                                                                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
TZ=Asia/Taipei

# =============================================================================
# Cloudflare Tunnel Token + MSSQL 密碼（官方標準版）
# =============================================================================
# 使用方式：複製本檔案為 .env
#   cp .env.template .env
# =============================================================================

# SQL Server SA 密碼（必須符合複雜度要求：大小寫英文 + 數字 + 特殊字元，至少 8 碼）
MSSQL_SA_PASSWORD=

# 可指定映像版本（預設 latest）
# BW_VERSION=2025.1.0

# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=

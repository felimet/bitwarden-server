# =============================================================================
# Bitwarden 官方標準版 設定檔（settings.env）
# =============================================================================
# 官方文件：https://bitwarden.com/help/install-on-premise-linux/
# ⚠️ 此方案需最低 4 GB RAM，不適用於 DS224+（2 GB）
# =============================================================================

###############
# 必填設定    #
###############

# Installation ID & Key（必填）
# 前往 https://bitwarden.com/host/ 免費申請
globalSettings__installation__id=
globalSettings__installation__key=

# 對外存取域名（不含 https:// 前綴）
globalSettings__baseServiceUri__vault=https://vault.example.com
globalSettings__baseServiceUri__api=https://vault.example.com/api
globalSettings__baseServiceUri__identity=https://vault.example.com/identity
globalSettings__baseServiceUri__admin=https://vault.example.com/admin
globalSettings__baseServiceUri__notifications=https://vault.example.com/notifications
globalSettings__baseServiceUri__internalNotifications=http://notifications:5000
globalSettings__baseServiceUri__internalAdmin=http://admin:5000
globalSettings__baseServiceUri__internalApi=http://api:5000
globalSettings__baseServiceUri__internalIdentity=http://identity:5000
globalSettings__baseServiceUri__internalVault=http://web:5000

# 資料庫連線字串（對應 docker-compose.yml 中的 MSSQL 設定）
globalSettings__sqlServer__connectionString=Data Source=tcp:mssql,1433;Initial Catalog=vault;Persist Security Info=False;User ID=sa;Password=CHANGE_THIS_PASSWORD;Multiple Active Result Sets=False;Connect Timeout=30;Encrypt=True;Trust Server Certificate=True

###############
# 選填設定    #
###############

# [SSL 設定] — 透過 Cloudflare Tunnel 反向代理時無須啟用
globalSettings__selfHosted=true
globalSettings__disableUserRegistration=false

# [SMTP 郵件通知設定]（選填，但強烈建議配置）
# globalSettings__mail__replyToEmail=noreply@example.com
# globalSettings__mail__smtp__host=smtp.gmail.com
# globalSettings__mail__smtp__port=587
# globalSettings__mail__smtp__ssl=false
# globalSettings__mail__smtp__startTls=true
# globalSettings__mail__smtp__username=your_email@gmail.com
# globalSettings__mail__smtp__password=your_app_password

# [Yubico 2FA]（選填）
# globalSettings__yubico__clientId=
# globalSettings__yubico__key=

# [Admin 面板 Token]
adminSettings__admins=

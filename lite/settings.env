# =============================================================================
# Bitwarden Lite 設定檔（settings.env）
# =============================================================================
# 官方文件：https://bitwarden.com/help/install-and-deploy-lite/
# 本檔案直接編輯後即可使用（無須複製），docker-compose.yml 透過 env_file 載入。
# =============================================================================

###############
# 必填設定    #
###############

# 對外存取域名（不含 https:// 前綴）
BW_DOMAIN=vault.example.com

# 資料庫設定 — 使用 SQLite（最輕量，適合 NAS 環境）
# 支援選項：sqlite / sqlserver / postgresql / mysql / mariadb
BW_DB_PROVIDER=sqlite
# SQLite 資料庫檔案路徑（選填，預設會在 /etc/bitwarden/ 下自動建立 vault.db）
# BW_DB_FILE=/etc/bitwarden/vault.db

# Installation ID & Key（必填）
# 前往 https://bitwarden.com/host/ 免費申請
BW_INSTALLATION_ID=
BW_INSTALLATION_KEY=

###############
# 選填設定    #
###############

# [SSL 設定]
# 因透過 Cloudflare Tunnel 反向代理，SSL 由 Cloudflare 處理，此處無須啟用
BW_ENABLE_SSL=false

# [服務開關]
BW_ENABLE_ADMIN=true
BW_ENABLE_API=true
BW_ENABLE_ICONS=true
BW_ENABLE_IDENTITY=true
BW_ENABLE_NOTIFICATIONS=true
BW_ENABLE_EVENTS=false
BW_ENABLE_SSO=false
BW_ENABLE_SCIM=false

# [圖示代理] — 啟用後可降低記憶體佔用（將圖示請求轉交雲端處理）
# 啟用此功能時，建議將 BW_ENABLE_ICONS 設為 false
# BW_ICONS_PROXY_TO_CLOUD=true

# [SMTP 郵件通知設定]（選填，但強烈建議配置）
# globalSettings__mail__replyToEmail=noreply@example.com
# globalSettings__mail__smtp__host=smtp.gmail.com
# globalSettings__mail__smtp__port=587
# globalSettings__mail__smtp__ssl=false
# globalSettings__mail__smtp__startTls=true
# globalSettings__mail__smtp__username=your_email@gmail.com
# globalSettings__mail__smtp__password=your_app_password
